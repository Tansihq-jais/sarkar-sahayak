# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Pinecone (free tier) ───────────────────────────────────
# Create free account at: https://pinecone.io
# Free tier: 1 index, 100K vectors
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=sarkar-sahayak

# ── Redis / Celery ─────────────────────────────────────────
# Local Redis (install from https://redis.io/downloads)
REDIS_URL=redis://localhost:6379/0
# OR free Upstash Redis: https://upstash.com (no Docker needed)
# REDIS_URL=rediss://default:your-token@your-host.upstash.io:6379

# ── Embedding model (local, free) ─────────────────────────
# Downloads ~90MB automatically on first run
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── AWS S3 (optional) ─────────────────────────────────────
# Skip if using client-side file processing
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET=sarkar-sahayak-docs

# ── OCR ───────────────────────────────────────────────────
TESSERACT_LANG=eng+hin

# ── App ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
APP_ENV=development
DEBUG=true
