# ── Ollama (local LLM) ─────────────────────────────────────
# Install: https://ollama.com/download/windows
# Pull model: ollama pull gemma2:2b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b

# ── App URL ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (free) ────────────────────────────────────────
# Create project at: https://supabase.com (free, no card)
# Find these in: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Rate Limiting (optional) ───────────────────────────────
# Free Vercel KV: https://vercel.com/storage/kv
# Leave empty to use in-memory rate limiting (fine for dev)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
